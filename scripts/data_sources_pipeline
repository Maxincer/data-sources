#!/usr/bin/env bash
#  Development:                DEV_MODE=1 bash scripts/data-sources-pipeline
#  Production:                 data-sources-pipeline

set -euo pipefail

TRADE_DATE="${1:-$(date +%Y%m%d)}"

WRITER_TABLE="t_futures_info_exchange"
#WRITER_TABLE="t_futures_info"  # phase 2
WRITER_OPTS="--table $WRITER_TABLE"

# DEV 模式：做两表对比（exchange vs t_futures_info），无 WSS
# 生产模式：跳过两表对比，仅做 WSS 交叉验证
REPORTER_OPTS="--table $WRITER_TABLE"
if [ "${DEV:-0}" != "1" ]; then
    REPORTER_OPTS="$REPORTER_OPTS --skip-table-compare"
fi

# ── 模式 ──
DEV="${DEV:-0}"

if [ "$DEV" = "1" ]; then
    # 开发模式
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    CWD="$(dirname "$SCRIPT_DIR")"
    cd "$CWD" || exit 1
    export DB_HOST="192.168.1.202"
    export DB_USER="root"
    export DB_PASSWORD="root0808"
    export DB_DATABASE="future_cn"

    # 比对库 (旧表 t_futures_info on 1.27)
    export REF_DB_HOST="192.168.1.27"
    export REF_DB_USER="tools"
    export REF_DB_PASSWORD="tools0512"
    export REF_DB_DATABASE="future_cn"

    # WSL 无 cpp_py，跳过 Wind WSS 交叉验证
    REPORTER_OPTS="$REPORTER_OPTS --skip-wind"
    PIP="$CWD/.venv/bin/python3"
    export DATA_DIR="$CWD/data"
    export LOG_DIR="$CWD/logs"
    export LD_LIBRARY_PATH="$HOME/.local/chrome-libs"
    export PLAYWRIGHT_BROWSERS_PATH="$HOME/.cache/ms-playwright"

    RUN_COLLECT="${PIP} -m data_sources.services.collect_announcements_service"
    RUN_ANALYSE="${PIP} -m data_sources.services.analyse_announcements_service"
    RUN_FETCHER="${PIP} -m data_sources.fetcher run ${TRADE_DATE}"
    RUN_WRITER="${PIP} -m data_sources.writer --date ${TRADE_DATE} ${WRITER_OPTS}"
    RUN_REPORTER="${PIP} -m data_sources.reporter ${TRADE_DATE}"
else
    # 生产模式：系统 Python 3.10
    export DB_HOST="192.168.1.27"
    export DB_USER="tools"
    export DB_PASSWORD="tools0512"
    export DB_DATABASE="future_cn"
    export DATA_DIR="/data2_backup/data_sources_data"
    export LOG_DIR="$HOME/log"
    export PLAYWRIGHT_BROWSERS_PATH="$HOME/playwright-browsers"
    export REF_DB_HOST="192.168.1.27"
    export REF_DB_USER="tools"
    export REF_DB_PASSWORD="tools0512"
    export REF_DB_DATABASE="future_cn"
    RUN_COLLECT="python3 -m data_sources.services.collect_announcements_service"
    RUN_ANALYSE="python3 -m data_sources.services.analyse_announcements_service"
    RUN_FETCHER="python3 -m data_sources.fetcher run ${TRADE_DATE}"
    RUN_WRITER="python3 -m data_sources.writer --date ${TRADE_DATE} ${WRITER_OPTS}"
    RUN_REPORTER="python3 -m data_sources.reporter ${TRADE_DATE}"
fi

# ---- 交易日判定 ----
TRADE_DATES_FILE="${DATA_DIR}/trade_dates.txt"
if [ -f "${TRADE_DATES_FILE}" ]; then
    if ! grep -qx "${TRADE_DATE}" "${TRADE_DATES_FILE}" 2>/dev/null; then
        echo "[$(date '+%F %T')] ${TRADE_DATE} 非交易日，跳过 pipeline"
        exit 0
    fi
else
    echo "[$(date '+%F %T')] ERROR: ${TRADE_DATES_FILE} 不存在，无法判定交易日"
    exit 1
fi

# ---- 时间门禁 ----
CURRENT_HM=$(date +%H%M)
if [ "$CURRENT_HM" -lt 1630 ]; then
    echo "[$(date '+%F %T')] 当前 ${CURRENT_HM} < 1630，跳过 pipeline"
    exit 0
fi

# ---- 密码与收件人（env var fallback，部署人员可通过 rutask env 覆写）----
export DAILY_START_DATE="${DAILY_START_DATE:-20251201}"
export DCE_API_KEY="${DCE_API_KEY:-ofxc69rpmd59}"
export DCE_API_SECRET="${DCE_API_SECRET:-2UdFW^2G4!4^7#@URqWx}"
export DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-sk-8421c2c981064cf58483df7bce947592}"
export ZHIPU_API_KEY="${ZHIPU_API_KEY:-f2f4fa94c73c4721ab3d7223548f49eb.e460UuOGcDGIuP6C}"
export ZHIPU_BASE_URL="${ZHIPU_BASE_URL:-https://open.bigmodel.cn/api/paas/v4/chat/completions}"
export ZHIPU_VISION_MODEL="${ZHIPU_VISION_MODEL:-glm-4v-flash}"
export FEISHU_WEBHOOK="${FEISHU_WEBHOOK:-https://open.feishu.cn/open-apis/bot/v2/hook/7f1c49ef-6e6b-4c19-8152-8e25dfb8d688}"
export FEISHU_ALERT_URL="$FEISHU_WEBHOOK"
export LLM_CONCURRENCY="${LLM_CONCURRENCY:-10}"
export SMTP_HOST="${SMTP_HOST:-smtp.exmail.qq.com}"
export SMTP_PASSWORD="${SMTP_PASSWORD:-NBnDH84qZHZWFrTC}"
export SMTP_PORT="${SMTP_PORT:-465}"
export TAVILY_API_KEY="${TAVILY_API_KEY:-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}"
export TUSHARE_TOKEN="${TUSHARE_TOKEN:-01f10e786b76dd6212829418aa979f3e578253f57eecbf0e12c9a44b}"
export WIND_RPC_HOST="${WIND_RPC_HOST:-192.168.2.9}"
export WIND_RPC_PORT="${WIND_RPC_PORT:-3801}"
export SENDER="${SENDER:-robot@wendao.fund}"
export RECIPIENTS="${RECIPIENTS:-mxz@wendao.fund}"

# ---- 执行管线 ----
echo "[$(date '+%F %T')] ===== pipeline started for ${TRADE_DATE} ====="

echo "[$(date '+%F %T')] Step 1/5: Collecting announcements..."
${RUN_COLLECT} 2>&1 || exit 1

echo "[$(date '+%F %T')] Step 2/5: Analyzing announcements..."
${RUN_ANALYSE} 2>&1 || exit 1

echo "[$(date '+%F %T')] Step 3/5: Fetching..."
${RUN_FETCHER} 2>&1 || exit 1

echo "[$(date '+%F %T')] Step 4/5: Writing..."
${RUN_WRITER} 2>&1 || exit 1

echo "[$(date '+%F %T')] Step 5/5: Reporting + email..."
${RUN_REPORTER} --sender "${SENDER}" --recipients "${RECIPIENTS}" ${REPORTER_OPTS} 2>&1 && rc=0 || rc=$?
STATUS=$rc
echo "reporter exit: $STATUS"
if [ $STATUS -ne 0 ]; then
    # 回滚：删除当日写入数据
    echo "[$(date '+%F %T')] 🔄 ROLLBACK triggered"
    mysql -h "${DB_HOST}" -u "${DB_USER}" -p"${DB_PASSWORD}" "${DB_DATABASE}" \
        -e "DELETE FROM \`${WRITER_TABLE}\` WHERE date='${TRADE_DATE}';"
    echo "[$(date '+%F %T')] ✅ 已删除 ${WRITER_TABLE} 中 ${TRADE_DATE} 的数据"
fi

echo "[$(date '+%F %T')] ===== pipeline finished (status=${STATUS}) ====="
exit $STATUS
